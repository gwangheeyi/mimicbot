<?xml version="1.0" ?>
<sdf version="1.9">

  <world name="camera_test_world">

    <!-- Gazebo 물리 엔진을 실행합니다. -->
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>

    <!-- Gazebo GUI와 월드 장면 정보를 공유합니다. -->
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster">
    </plugin>

    <!-- 카메라, 라이다 등 Gazebo 센서를 작동시킵니다. -->
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">

      <!-- 카메라 렌더링 엔진으로 Ogre2를 사용합니다. -->
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- 월드 조명 -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>

      <pose>0 0 10 0 0 0</pose>

      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>

      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>

      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- 바닥 -->
    <model name="ground_plane">
      <static>true</static>

      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </collision>

        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>

          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 카메라 영상에서 확인할 테스트 상자 -->
    <model name="red_box">
      <static>true</static>

      <!-- 월드 원점에 높이 0.5m로 배치 -->
      <pose>0 0 0.5 0 0 0</pose>

      <link name="box_link">
        <collision name="box_collision">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
        </collision>

        <visual name="box_visual">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>

          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 월드에 고정된 가상 카메라 -->
    <model name="fixed_camera">
      <static>true</static>

      <!--
        카메라 위치:
          x = 3m
          y = 0m
          z = 1.5m

        yaw = 3.14159로 회전시켜
        월드 원점 방향을 바라보게 합니다.
      -->
      <pose>3 0 1.5 0 0 3.14159</pose>

      <link name="camera_link">

        <!-- 카메라 위치를 확인하기 위한 작은 상자 -->
        <visual name="camera_body">
          <geometry>
            <box>
              <size>0.2 0.15 0.15</size>
            </box>
          </geometry>

          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>

        <!-- RGB 카메라 센서 -->
        <sensor name="rgb_camera" type="camera">

          <!-- 시뮬레이션 중 항상 센서를 작동합니다. -->
          <always_on>true</always_on>

          <!-- 초당 30장의 영상을 생성합니다. -->
          <update_rate>30</update_rate>

          <!-- Gazebo Transport에서 사용할 토픽 이름입니다. -->
          <topic>/gazebo/camera/image</topic>

          <!-- Gazebo GUI에서 카메라 시야를 표시합니다. -->
          <visualize>true</visualize>

          <camera>

            <!-- 약 60도의 수평 화각 -->
            <horizontal_fov>1.047</horizontal_fov>

            <!-- 출력 영상 설정 -->
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>

            <!-- 카메라가 볼 수 있는 최소·최대 거리 -->
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>

          </camera>
        </sensor>

      </link>
    </model>

  </world>

</sdf>

<?xml version="1.0" ?>
<sdf version="1.9">

  <world name="camera_test_world">
<!-- Gazebo GUI에서 모델 이동, 회전, 삭제 명령을 처리합니다. -->
<plugin
  filename="gz-sim-user-commands-system"
  name="gz::sim::systems::UserCommands">
</plugin>	

    <!-- Gazebo 물리 엔진을 실행합니다. -->
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics"/>

    <!-- Gazebo 화면에 모델과 월드를 표시합니다. -->
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster"/>

    <!-- 카메라와 라이다 같은 렌더링 센서를 실행합니다. -->
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- 햇빛 -->
    <light type="directional" name="sun">
      <pose>0 0 10 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- 바닥 -->
    <model name="ground_plane">
      <static>true</static>

      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </collision>

        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>

          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 카메라로 촬영할 빨간 상자 -->
    <model name="red_box">
      <static>false</static>
      <pose>0 0 0.5 0 0 0</pose>

      <link name="box_link">
        <collision name="box_collision">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
        </collision>

        <visual name="box_visual">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>

          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 월드에 고정된 카메라 -->
    <model name="fixed_camera">
      <static>true</static>

      <!--
        카메라는 x=3m, z=1.5m 위치에 있습니다.
        yaw를 약 180도 회전시켜 원점을 바라보게 합니다.
      -->
      <pose>3 0 1.5 0 0 3.141592</pose>

      <link name="camera_link">

        <visual name="camera_body">
          <geometry>
            <box>
              <size>0.2 0.15 0.15</size>
            </box>
          </geometry>

          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>

        <!-- RGB 카메라 센서 -->
        <sensor name="rgb_camera" type="camera">
          <always_on>true</always_on>
          <update_rate>30</update_rate>
          <topic>/gazebo/camera/image</topic>
          <visualize>true</visualize>

          <camera>
            <horizontal_fov>1.047</horizontal_fov>

            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>

            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
          </camera>
        </sensor>

      </link>
    </model>

  </world>

</sdf>
